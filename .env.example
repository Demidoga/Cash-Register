# Copy to .env (`cp .env.example .env`) and fill in. Docker Compose loads this
# file automatically. .env holds secrets — keep it out of git.

# --- Database (Supabase Postgres) ---
# REQUIRED. The "Connection pooling" string from Supabase -> Project Settings ->
# Database. Use the POOLER string, NOT the direct one (direct is IPv6-only and
# connection-limited). Session mode (port 5432 on the pooler host) suits a
# long-running container. Append ?sslmode=require if it isn't already present.
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# A bare postgresql:// URL is auto-normalized to the psycopg driver.
DATABASE_URL=
# Set true ONLY if you use the transaction-mode pooler (port 6543), which
# rejects server-side prepared statements.
DB_DISABLE_PREPARED_STATEMENTS=false

# --- API auth ---
# REQUIRED. Generate one, e.g.:  openssl rand -hex 32
JWT_SECRET=
JWT_AUDIENCE=authenticated

# Leave SUPABASE_URL blank to verify tokens with the shared JWT_SECRET (HS256).
# Set it to your Supabase project URL to verify via JWKS (ES256/RS256) instead.
SUPABASE_URL=

# --- Clinic ---
# Fallback clinic name used only if first-time setup is run without one. The
# setup wizard collects the name and currency, so this is just a default.
CLINIC_NAME=My Clinic

# Dev login mints a JWT for any email (no Supabase needed). MUST stay false in
# any real deployment. Set to true only for a throwaway local trial.
DEV_LOGIN_ENABLED=false

# --- Frontend (baked into the web bundle at build time) ---
# Leave both blank to use the API's dev login. Set them to wire up Supabase auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
