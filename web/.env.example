# Frontend environment. Copy to `.env.local` and fill in.

# API base path (defaults to /api when omitted).
# VITE_API_BASE=/api

# Supabase — enables real Google + email/password sign-in.
# Leave both blank to use the local dev login instead.
# Find these in Supabase: Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

